<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            stylesheets="@../css/styles.css"
            styleClass="main-background"
            fx:controller="org.example.agenciadeviajes.controller.AutosController">

    <top>

        <VBox spacing="10"
              styleClass="top-bar warning-bar">

            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <Label text="Consulta de Autos"
                   styleClass="section-title"/>

        </VBox>

    </top>

    <center>

        <VBox spacing="15"
              styleClass="panel-surface">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <HBox spacing="10">

                <DatePicker fx:id="dpFechaInicio"
                            promptText="Fecha Inicio"
                            styleClass="modern-input"/>

                <DatePicker fx:id="dpFechaFin"
                            promptText="Fecha Fin"
                            styleClass="modern-input"/>

            </HBox>

            <TableView fx:id="tablaAutos"
                       prefHeight="500"
                       styleClass="modern-table">

                <columns>

                    <TableColumn fx:id="colMarca"
                                 text="Marca"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colModelo"
                                 text="Modelo"
                                 prefWidth="140"/>

                    <TableColumn fx:id="colCategoria"
                                 text="Categoría"
                                 prefWidth="140"/>

                    <TableColumn fx:id="colProveedor"
                                 text="Proveedor"
                                 prefWidth="160"/>

                    <TableColumn fx:id="colCiudad"
                                 text="Ciudad"
                                 prefWidth="140"/>

                    <TableColumn fx:id="colPrecio"
                                 text="Precio/Día"
                                 prefWidth="140"/>

                </columns>

            </TableView>

            <Button text="Reservar Auto"
                    prefWidth="220"
                    onAction="#reservarAuto"
                    styleClass="primary-button"/>

            <Button text="Volver al Home"
                    prefWidth="220"
                    onAction="#volverHome"
                    styleClass="secondary-button"/>

        </VBox>

    </center>

</BorderPane>