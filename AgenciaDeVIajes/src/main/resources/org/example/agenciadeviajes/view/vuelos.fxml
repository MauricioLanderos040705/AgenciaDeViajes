<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.agenciadeviajes.controller.VuelosController"
           stylesheets="@../css/styles.css">

    <Pane styleClass="page-background"/>

    <Pane styleClass="overlay"/>

    <BorderPane>

        <top>

            <VBox spacing="5">

                <padding>
                    <Insets top="24" left="30"/>
                </padding>

                <Label text="Consulta de Vuelos"
                       styleClass="page-title"/>

                <Label text="Explora vuelos disponibles para tu viaje"
                       styleClass="page-subtitle"/>

            </VBox>

        </top>

        <center>

            <VBox alignment="CENTER"
                  spacing="18">

                <padding>
                    <Insets top="10" right="25" bottom="25" left="25"/>
                </padding>

                <VBox spacing="18"
                      styleClass="glass-card"
                      maxWidth="1150">

                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <TableView fx:id="tablaVuelos"
                               prefHeight="480">

                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>

                        <columns>

                            <TableColumn fx:id="colAerolinea" text="Aerolínea"/>
                            <TableColumn fx:id="colOrigen" text="Origen"/>
                            <TableColumn fx:id="colDestino" text="Destino"/>
                            <TableColumn fx:id="colSalida" text="Salida"/>
                            <TableColumn fx:id="colPrecio" text="Precio"/>
                            <TableColumn fx:id="colAsientos" text="Asientos"/>

                        </columns>

                    </TableView>

                    <HBox spacing="18"
                          alignment="CENTER">

                        <Button text="✈ Reservar Vuelo"
                                prefWidth="240"
                                prefHeight="42"
                                onAction="#reservarVuelo"
                                styleClass="primary-btn"/>

                        <Button text="← Volver"
                                prefWidth="180"
                                prefHeight="42"
                                onAction="#volverHome"
                                styleClass="secondary-btn"/>

                    </HBox>

                </VBox>

            </VBox>

        </center>

    </BorderPane>

</StackPane>