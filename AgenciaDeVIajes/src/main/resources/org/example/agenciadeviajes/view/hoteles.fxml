<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.agenciadeviajes.controller.HotelesController"
           stylesheets="@../css/styles.css">

    <Pane styleClass="page-background"/>

    <Pane styleClass="overlay"/>

    <BorderPane>

        <top>

            <VBox spacing="5">

                <padding>
                    <Insets top="24" left="30"/>
                </padding>

                <Label text="Consulta de Hoteles"
                       styleClass="page-title"/>

                <Label text="Encuentra hospedajes increíbles"
                       styleClass="page-subtitle"/>

            </VBox>

        </top>

        <center>

            <VBox alignment="CENTER"
                  spacing="18">

                <padding>
                    <Insets top="10" right="25" bottom="25" left="25"/>
                </padding>

                <VBox spacing="18"
                      styleClass="glass-card"
                      maxWidth="1180">

                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <HBox spacing="12">

                        <DatePicker fx:id="dpCheckIn"
                                    promptText="Check-In"/>

                        <DatePicker fx:id="dpCheckOut"
                                    promptText="Check-Out"/>

                        <Spinner fx:id="spHabitaciones"
                                 prefWidth="140"/>

                    </HBox>

                    <TableView fx:id="tablaHoteles"
                               prefHeight="430">

                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>

                        <columns>

                            <TableColumn fx:id="colNombre" text="Hotel"/>
                            <TableColumn fx:id="colCiudad" text="Ciudad"/>
                            <TableColumn fx:id="colPais" text="País"/>
                            <TableColumn fx:id="colEstrellas" text="Estrellas"/>
                            <TableColumn fx:id="colPrecio" text="Precio/Noche"/>
                            <TableColumn fx:id="colHabitaciones" text="Habitaciones"/>

                        </columns>

                    </TableView>

                    <HBox spacing="18"
                          alignment="CENTER">

                        <Button text="🏨 Reservar Hotel"
                                prefWidth="240"
                                prefHeight="42"
                                onAction="#reservarHotel"
                                styleClass="primary-btn"/>

                        <Button text="← Volver"
                                prefWidth="180"
                                prefHeight="42"
                                onAction="#volverHome"
                                styleClass="secondary-btn"/>

                    </HBox>

                </VBox>

            </VBox>

        </center>

    </BorderPane>

</StackPane>