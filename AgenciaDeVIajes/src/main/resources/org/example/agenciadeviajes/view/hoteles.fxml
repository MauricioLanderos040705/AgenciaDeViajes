<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            stylesheets="@../css/styles.css"
            styleClass="main-background"
            fx:controller="org.example.agenciadeviajes.controller.HotelesController">

    <top>

        <VBox spacing="10"
              styleClass="top-bar success-bar">

            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <Label text="Consulta de Hoteles"
                   styleClass="section-title"/>

        </VBox>

    </top>

    <center>

        <VBox spacing="15"
              styleClass="panel-surface"
              VBox.vgrow="ALWAYS">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <HBox spacing="10">

                <DatePicker fx:id="dpCheckIn"
                            promptText="Check-In"
                            styleClass="modern-input"/>

                <DatePicker fx:id="dpCheckOut"
                            promptText="Check-Out"
                            styleClass="modern-input"/>

                <Spinner fx:id="spHabitaciones"
                         prefWidth="120"
                         styleClass="modern-input"/>

            </HBox>

            <TableView fx:id="tablaHoteles"
                       prefHeight="600"
                       VBox.vgrow="ALWAYS"
                       styleClass="modern-table">

                <columns>

                    <TableColumn fx:id="colNombre"
                                 text="Hotel"
                                 prefWidth="180"/>

                    <TableColumn fx:id="colCiudad"
                                 text="Ciudad"
                                 prefWidth="140"/>

                    <TableColumn fx:id="colPais"
                                 text="País"
                                 prefWidth="140"/>

                    <TableColumn fx:id="colEstrellas"
                                 text="Estrellas"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colPrecio"
                                 text="Precio/Noche"
                                 prefWidth="140"/>

                    <TableColumn fx:id="colHabitaciones"
                                 text="Habitaciones"
                                 prefWidth="120"/>

                </columns>

            </TableView>

            <Button text="Reservar Hotel"
                    prefWidth="220"
                    onAction="#reservarHotel"
                    styleClass="primary-button"/>

            <Button text="Volver al Home"
                    prefWidth="220"
                    onAction="#volverHome"
                    styleClass="secondary-button"/>

        </VBox>

    </center>

</BorderPane>