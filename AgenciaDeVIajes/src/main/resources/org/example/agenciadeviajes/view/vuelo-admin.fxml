<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.agenciadeviajes.admin.VueloAdminController"
           stylesheets="@../css/styles.css">

    <Pane styleClass="page-background"/>

    <Pane styleClass="overlay"/>

    <VBox spacing="20"
          alignment="TOP_CENTER">

        <padding>
            <Insets top="24" right="28" bottom="24" left="28"/>
        </padding>

        <!-- HEADER -->

        <VBox alignment="CENTER"
              spacing="5">

            <Label text="Administrar Vuelos"
                   styleClass="page-title"/>

            <Label text="Gestiona vuelos y disponibilidad"
                   styleClass="page-subtitle"/>

        </VBox>

        <!-- CONTENT -->

        <VBox spacing="18"
              maxWidth="1250"
              styleClass="glass-card">

            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>

            <!-- TABLE -->

            <TableView fx:id="tablaVuelos"
                       prefHeight="280">

                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>

                <columns>

                    <TableColumn fx:id="colId" text="ID"/>
                    <TableColumn fx:id="colAerolinea" text="Aerolínea"/>
                    <TableColumn fx:id="colOrigen" text="Origen"/>
                    <TableColumn fx:id="colDestino" text="Destino"/>

                </columns>

            </TableView>

            <!-- FORM -->

            <GridPane hgap="15"
                      vgap="15">

                <columnConstraints>
                    <ColumnConstraints percentWidth="15"/>
                    <ColumnConstraints percentWidth="35"/>
                    <ColumnConstraints percentWidth="15"/>
                    <ColumnConstraints percentWidth="35"/>
                </columnConstraints>

                <!-- ROW 1 -->

                <Label text="Aerolínea:"
                       styleClass="section-title"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="cbAerolinea"
                          GridPane.rowIndex="0"
                          GridPane.columnIndex="1"/>

                <Label text="Origen:"
                       styleClass="section-title"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="2"/>

                <ComboBox fx:id="cbOrigen"
                          GridPane.rowIndex="0"
                          GridPane.columnIndex="3"/>

                <!-- ROW 2 -->

                <Label text="Destino:"
                       styleClass="section-title"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="cbDestino"
                          GridPane.rowIndex="1"
                          GridPane.columnIndex="1"/>

                <Label text="Salida:"
                       styleClass="section-title"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="2"/>

                <DatePicker fx:id="dpFecha"
                            GridPane.rowIndex="1"
                            GridPane.columnIndex="3"/>

                <!-- ROW 3 -->

                <Label text="Asientos:"
                       styleClass="section-title"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtAsientos"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="1"/>

                <Label text="Precio:"
                       styleClass="section-title"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="2"/>

                <TextField fx:id="txtPrecio"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="3"/>

                <!-- ROW 4 -->

                <Label text="Divisa:"
                       styleClass="section-title"
                       GridPane.rowIndex="3"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="cbDivisa"
                          GridPane.rowIndex="3"
                          GridPane.columnIndex="1"/>

            </GridPane>

            <!-- BUTTONS -->

            <HBox spacing="16"
                  alignment="CENTER">

                <Button fx:id="btnCrear"
                        text="➕ Crear"
                        prefWidth="150"
                        prefHeight="42"
                        onAction="#crearVuelo"
                        styleClass="primary-btn"/>

                <Button fx:id="btnActualizar"
                        text="✏ Actualizar"
                        prefWidth="150"
                        prefHeight="42"
                        onAction="#actualizarVuelo"
                        styleClass="secondary-btn"
                        disable="true"/>

                <Button fx:id="btnEliminar"
                        text="🗑 Eliminar"
                        prefWidth="150"
                        prefHeight="42"
                        onAction="#eliminarVuelo"
                        disable="true"
                        style="-fx-background-color:
                                      linear-gradient(
                                          to right,
                                          #EF5350,
                                          #C62828
                                      );

                               -fx-text-fill: white;

                               -fx-font-weight: bold;"/>

                <Button fx:id="btnLimpiar"
                        text="🧹 Limpiar"
                        prefWidth="150"
                        prefHeight="42"
                        onAction="#limpiar"
                        styleClass="secondary-btn"/>

            </HBox>

        </VBox>

    </VBox>

</StackPane>