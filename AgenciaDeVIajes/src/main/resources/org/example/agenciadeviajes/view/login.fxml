<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.agenciadeviajes.controller.LoginController"
           stylesheets="@../css/styles.css">

    <!-- BACKGROUND -->

    <Pane styleClass="page-background"/>

    <Pane styleClass="overlay"/>

    <!-- CONTENT -->

    <VBox alignment="CENTER">

        <VBox alignment="CENTER"
              spacing="20"
              maxWidth="430"
              styleClass="glass-card">

            <padding>
                <Insets top="35" right="35" bottom="35" left="35"/>
            </padding>

            <!-- LOGO -->

            <Label text="✈"
                   style="-fx-font-size: 60px;"/>

            <!-- TITLES -->

            <VBox alignment="CENTER"
                  spacing="5">

                <Label text="Agencia de Viajes"
                       styleClass="page-title"/>

                <Label text="Inicia sesión y comienza tu próxima aventura"
                       styleClass="page-subtitle"/>

            </VBox>

            <!-- INPUTS -->

            <VBox spacing="14"
                  alignment="CENTER">

                <TextField fx:id="txtCorreo"
                           promptText="Correo electrónico"
                           prefWidth="320"
                           prefHeight="42"/>

                <PasswordField fx:id="txtPassword"
                               promptText="Contraseña"
                               prefWidth="320"
                               prefHeight="42"/>

            </VBox>

            <!-- BUTTONS -->

            <VBox spacing="12"
                  alignment="CENTER">

                <Button text="Iniciar Sesión"
                        prefWidth="240"
                        prefHeight="44"
                        onAction="#iniciarSesion"
                        styleClass="primary-btn"/>

                <Button text="Crear Cuenta"
                        prefWidth="240"
                        prefHeight="44"
                        onAction="#abrirRegistro"
                        styleClass="secondary-btn"/>

            </VBox>

            <!-- MESSAGE -->

            <Label fx:id="lblMensaje"
                   wrapText="true"
                   style="-fx-text-fill: #FFCDD2;
                          -fx-font-size: 13px;
                          -fx-font-weight: bold;"/>

        </VBox>

    </VBox>

</StackPane>