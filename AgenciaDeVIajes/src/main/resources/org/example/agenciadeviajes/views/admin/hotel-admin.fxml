<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="10" style="-fx-padding: 15;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.agenciadeviajes.admin.HotelAdminController">
   <Label text="Hoteles" style="-fx-font-size: 18; -fx-font-weight: bold;" />

   <TableView fx:id="tablaHoteles" prefHeight="250" VBox.vgrow="ALWAYS">
      <columns>
         <TableColumn fx:id="colId" prefWidth="50" text="ID" />
         <TableColumn fx:id="colNombre" prefWidth="150" text="Nombre" />
         <TableColumn fx:id="colCiudad" prefWidth="120" text="Ciudad" />
         <TableColumn fx:id="colEstrellas" prefWidth="80" text="Estrellas" />
      </columns>
   </TableView>

   <VBox spacing="8" style="-fx-border-top: 1px solid #ccc; -fx-padding-top: 10;">
      <Label text="Formulario" style="-fx-font-weight: bold;" />

      <HBox spacing="10">
         <Label text="Nombre:" minWidth="80" />
         <TextField fx:id="txtNombre" prefWidth="150" />
         <Label text="Ciudad:" minWidth="80" />
         <ComboBox fx:id="cbCiudad" prefWidth="150" />
      </HBox>

      <HBox spacing="10">
         <Label text="Estrellas:" minWidth="80" />
         <Spinner fx:id="spEstrellas" prefWidth="100" />
         <Label text="Precio:" minWidth="80" />
         <TextField fx:id="txtPrecio" prefWidth="100" />
      </HBox>

      <HBox spacing="10">
         <Label text="Divisa:" minWidth="80" />
         <ComboBox fx:id="cbDivisa" prefWidth="150" />
      </HBox>

      <HBox spacing="10">
         <Button fx:id="btnCrear" text="➕ Crear" />
         <Button fx:id="btnActualizar" text="💾 Actualizar" disable="true" />
         <Button fx:id="btnEliminar" text="🗑️ Eliminar" disable="true" />
         <Button fx:id="btnLimpiar" text="🧹 Limpiar" />
      </HBox>
   </VBox>
</VBox>
