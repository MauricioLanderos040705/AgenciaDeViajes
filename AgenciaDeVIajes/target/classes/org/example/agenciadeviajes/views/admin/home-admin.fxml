<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.agenciadeviajes.admin.AdminHomeController" fx:id="root">
   <top>
      <VBox style="-fx-background-color: #2c3e50;" spacing="10">
         <Label text="🔧 PANEL DE ADMINISTRACIÓN" textFill="WHITE" style="-fx-font-size: 20; -fx-font-weight: bold;">
            <VBox.margin>
               <Insets left="15" top="10" />
            </VBox.margin>
         </Label>
         <Label fx:id="lblUsuario" textFill="#bdc3c7">
            <VBox.margin>
               <Insets left="15" bottom="10" />
            </VBox.margin>
         </Label>
      </VBox>
   </top>

   <left>
      <VBox style="-fx-background-color: #ecf0f1;" minWidth="180">
         <Label text="MENÚ" style="-fx-font-weight: bold;">
            <VBox.margin>
               <Insets left="15" top="15" />
            </VBox.margin>
         </Label>
         <ListView fx:id="menuAdmin" VBox.vgrow="ALWAYS" />
      </VBox>
   </left>

   <center>
      <VBox style="-fx-background-color: white;" spacing="15">
         <Label text="Selecciona un módulo del menú">
            <VBox.margin>
               <Insets left="20" top="20" />
            </VBox.margin>
         </Label>
      </VBox>
   </center>
</BorderPane>
