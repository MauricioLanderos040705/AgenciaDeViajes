<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" style="-fx-padding: 15;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.agenciadeviajes.admin.VueloAdminController">
   <Label text="Vuelos" style="-fx-font-size: 18; -fx-font-weight: bold;" />

   <TableView fx:id="tablaVuelos" prefHeight="250" VBox.vgrow="ALWAYS">
      <columns>
         <TableColumn fx:id="colId" prefWidth="50" text="ID" />
         <TableColumn fx:id="colAerolinea" prefWidth="120" text="Aerolínea" />
         <TableColumn fx:id="colOrigen" prefWidth="100" text="Origen" />
         <TableColumn fx:id="colDestino" prefWidth="100" text="Destino" />
      </columns>
   </TableView>

   <VBox spacing="8" style="-fx-border-top: 1px solid #ccc; -fx-padding-top: 10;">
      <Label text="Formulario" style="-fx-font-weight: bold;" />

      <HBox spacing="10">
         <Label text="Aerolínea:" minWidth="80" />
         <ComboBox fx:id="cbAerolinea" prefWidth="150" />
         <Label text="Origen:" minWidth="80" />
         <ComboBox fx:id="cbOrigen" prefWidth="150" />
      </HBox>

      <HBox spacing="10">
         <Label text="Destino:" minWidth="80" />
         <ComboBox fx:id="cbDestino" prefWidth="150" />
         <Label text="Fecha:" minWidth="80" />
         <DatePicker fx:id="dpFecha" prefWidth="150" />
      </HBox>

      <HBox spacing="10">
         <Label text="Asientos:" minWidth="80" />
         <TextField fx:id="txtAsientos" prefWidth="100" />
         <Label text="Precio:" minWidth="80" />
         <TextField fx:id="txtPrecio" prefWidth="100" />
      </HBox>

      <HBox spacing="10">
         <Label text="Divisa:" minWidth="80" />
         <ComboBox fx:id="cbDivisa" prefWidth="150" />
      </HBox>

      <HBox spacing="10">
         <Button fx:id="btnCrear" text="➕ Crear" />
         <Button fx:id="btnActualizar" text="💾 Actualizar" disable="true" />
         <Button fx:id="btnEliminar" text="🗑️ Eliminar" disable="true" />
         <Button fx:id="btnLimpiar" text="🧹 Limpiar" />
      </HBox>
   </VBox>
</VBox>
