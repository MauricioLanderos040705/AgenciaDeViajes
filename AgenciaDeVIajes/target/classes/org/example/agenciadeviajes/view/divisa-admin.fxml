<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            stylesheets="@../css/styles.css"
            styleClass="main-background"
            fx:controller="org.example.agenciadeviajes.admin.DivisaAdminController">

    <top>
        <VBox spacing="10"
              alignment="CENTER"
              styleClass="top-bar">

            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <Label text="Administrar Divisas"
                   styleClass="section-title"/>

        </VBox>
    </top>

    <center>

        <VBox spacing="15"
              styleClass="panel-surface"
              VBox.vgrow="ALWAYS">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <TableView fx:id="tablaDivisas"
                       prefHeight="550"
                       VBox.vgrow="ALWAYS"
                       styleClass="modern-table">

                <columns>

                    <TableColumn fx:id="colCodigo"
                                 text="Código ISO"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colNombre"
                                 text="Nombre"
                                 prefWidth="180"/>

                    <TableColumn fx:id="colSimbolo"
                                 text="Símbolo"
                                 prefWidth="100"/>

                </columns>

            </TableView>

            <HBox spacing="15">

                <padding>
                    <Insets top="10"/>
                </padding>

                <Label text="Nombre:"
                       prefWidth="80"/>
                <TextField fx:id="txtNombre"
                           prefWidth="200"/>

            </HBox>

            <HBox spacing="15">

                <Label text="Símbolo:"
                       prefWidth="80"/>
                <TextField fx:id="txtSimbolo"
                           prefWidth="200"/>

            </HBox>

            <HBox spacing="15">

                <Label text="Código ISO:"
                       prefWidth="80"/>
                <TextField fx:id="txtCodigo"
                           prefWidth="200"/>

            </HBox>

            <HBox spacing="10">

                <padding>
                    <Insets top="15"/>
                </padding>

                <Button fx:id="btnCrear"
                        text="Crear"
                        prefWidth="100"
                        onAction="#crearDivisa"
                        styleClass="primary-button"/>

                <Button fx:id="btnActualizar"
                        text="Actualizar"
                        prefWidth="100"
                        onAction="#actualizarDivisa"
                        styleClass="secondary-button"
                        disable="true"/>

                <Button fx:id="btnEliminar"
                        text="Eliminar"
                        prefWidth="100"
                        onAction="#eliminarDivisa"
                        styleClass="danger-button"
                        disable="true"/>

                <Button fx:id="btnLimpiar"
                        text="Limpiar"
                        prefWidth="100"
                        onAction="#limpiar"
                        styleClass="secondary-button"/>

                <Separator prefWidth="30"/>

                <Button fx:id="btnRegresar"
                        text="← Regresar"
                        prefWidth="100"
                        onAction="#regresar"
                        styleClass="secondary-button"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>
