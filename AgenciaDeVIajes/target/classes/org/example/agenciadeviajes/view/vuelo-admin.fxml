<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            stylesheets="@../css/styles.css"
            styleClass="main-background"
            fx:controller="org.example.agenciadeviajes.admin.VueloAdminController">

    <top>
        <VBox spacing="10"
              alignment="CENTER"
              styleClass="top-bar">

            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <Label text="Administrar Vuelos"
                   styleClass="section-title"/>

        </VBox>
    </top>

    <center>

        <VBox spacing="15"
              styleClass="panel-surface"
              VBox.vgrow="ALWAYS">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <TableView fx:id="tablaVuelos"
                       prefHeight="550"
                       VBox.vgrow="ALWAYS"
                       styleClass="modern-table">

                <columns>

                    <TableColumn fx:id="colId"
                                 text="ID"
                                 prefWidth="50"/>

                    <TableColumn fx:id="colAerolinea"
                                 text="Aerolínea"
                                 prefWidth="110"/>

                    <TableColumn fx:id="colOrigen"
                                 text="Origen"
                                 prefWidth="85"/>

                    <TableColumn fx:id="colDestino"
                                 text="Destino"
                                 prefWidth="85"/>

                    <TableColumn fx:id="colSalida"
                                 text="Salida"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colLlegada"
                                 text="Llegada"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colPrecio"
                                 text="Precio"
                                 prefWidth="80"/>

                    <TableColumn fx:id="colDivisa"
                                 text="Divisa"
                                 prefWidth="70"/>

                    <TableColumn fx:id="colAsientos"
                                 text="Disponibles"
                                 prefWidth="85"/>

                    <TableColumn fx:id="colRedondo"
                                 text="Redondo"
                                 prefWidth="70"/>

                </columns>

            </TableView>

            <HBox spacing="15">

                <padding>
                    <Insets top="10"/>
                </padding>

                <Label text="Aerolínea:"
                       prefWidth="80"/>
                <ComboBox fx:id="cbAerolinea"
                          prefWidth="200"/>

            </HBox>

            <HBox spacing="15">

                <Label text="Origen:"
                       prefWidth="80"/>
                <ComboBox fx:id="cbOrigen"
                          prefWidth="200"/>

            </HBox>

            <HBox spacing="15">

                <Label text="Destino:"
                       prefWidth="80"/>
                <ComboBox fx:id="cbDestino"
                          prefWidth="200"/>

            </HBox>

            <HBox spacing="15">

                <Label text="Salida:"
                       prefWidth="80"/>
                <DatePicker fx:id="dpFecha"
                            prefWidth="200"/>

            </HBox>

            <HBox spacing="15">

                <Label text="Asientos:"
                       prefWidth="80"/>
                <TextField fx:id="txtAsientos"
                           prefWidth="200"/>

            </HBox>

            <HBox spacing="15">

                <Label text="Precio:"
                       prefWidth="80"/>
                <TextField fx:id="txtPrecio"
                           prefWidth="200"/>

            </HBox>

            <HBox spacing="15">

                <Label text="Divisa:"
                       prefWidth="80"/>
                <ComboBox fx:id="cbDivisa"
                          prefWidth="200"/>

            </HBox>

            <HBox spacing="15">

                <Label text="¿Redondo?"
                       prefWidth="80"/>
                <CheckBox fx:id="chkRedondo"
                          prefWidth="200"/>

            </HBox>

            <HBox spacing="10">

                <padding>
                    <Insets top="15"/>
                </padding>

                <Button fx:id="btnCrear"
                        text="Crear"
                        prefWidth="100"
                        onAction="#crearVuelo"
                        styleClass="primary-button"/>

                <Button fx:id="btnActualizar"
                        text="Actualizar"
                        prefWidth="100"
                        onAction="#actualizarVuelo"
                        styleClass="secondary-button"
                        disable="true"/>

                <Button fx:id="btnEliminar"
                        text="Eliminar"
                        prefWidth="100"
                        onAction="#eliminarVuelo"
                        styleClass="danger-button"
                        disable="true"/>

                <Button fx:id="btnLimpiar"
                        text="Limpiar"
                        prefWidth="100"
                        onAction="#limpiar"
                        styleClass="secondary-button"/>

                <Separator prefWidth="30"/>

                <Button fx:id="btnRegresar"
                        text="← Regresar"
                        prefWidth="100"
                        onAction="#regresar"
                        styleClass="secondary-button"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>
