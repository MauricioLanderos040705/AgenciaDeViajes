<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER"
      spacing="15"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.agenciadeviajes.controller.LoginController">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Agencia de Viajes"
           style="-fx-font-size: 24px; -fx-font-weight: bold;" />

    <TextField fx:id="txtCorreo"
               promptText="Correo" />

    <PasswordField fx:id="txtPassword"
                   promptText="Contraseña" />

    <Button text="Iniciar Sesión"
            onAction="#iniciarSesion"
            prefWidth="200"/>
    <Button text="Crear cuenta"
            onAction="#abrirRegistro"
            prefWidth="200"/>

    <Label fx:id="lblMensaje"
           style="-fx-text-fill: red;" />

</VBox>