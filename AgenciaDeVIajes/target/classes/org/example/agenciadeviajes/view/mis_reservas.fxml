<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="25"
      alignment="TOP_CENTER"
      prefWidth="1020"
      prefHeight="720"
      stylesheets="@../css/styles.css"
      styleClass="main-background"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.agenciadeviajes.controller.MisReservasController">

    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <VBox alignment="CENTER" spacing="5">
        <Label text="MIS RESERVAS" styleClass="main-title-dark"/>
        <Label text="Gestiona y consulta el estado de tus itinerarios contratados" styleClass="main-subtitle"/>
    </VBox>

    <VBox styleClass="table-container" VBox.vgrow="ALWAYS">
        <TableView fx:id="tablaReservas"
                   prefHeight="240"
                   styleClass="modern-table">
            <columns>
                <TableColumn fx:id="colFolio" text="Folio" minWidth="120"/>
                <TableColumn fx:id="colFecha" text="Fecha de Registro" minWidth="180"/>
                <TableColumn fx:id="colTipo" text="Tipo de Servicio" minWidth="150"/>
                <TableColumn fx:id="colTotal" text="Total Facturado" minWidth="140"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

    <HBox spacing="20" alignment="CENTER" HBox.hgrow="ALWAYS">

        <VBox spacing="12" styleClass="panel-surface" HBox.hgrow="ALWAYS">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="" styleClass="panel-icon"/>
                <Label text="Vuelos Disponibles" styleClass="subsection-title"/>
            </HBox>
            <ListView fx:id="listVuelos" prefHeight="180" styleClass="modern-list-view" VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox spacing="12" styleClass="panel-surface" HBox.hgrow="ALWAYS">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="" styleClass="panel-icon"/>
                <Label text="Hoteles Reservados" styleClass="subsection-title"/>
            </HBox>
            <ListView fx:id="listHoteles" prefHeight="180" styleClass="modern-list-view" VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox spacing="12" styleClass="panel-surface" HBox.hgrow="ALWAYS">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="" styleClass="panel-icon"/>
                <Label text="Renta de Autos" styleClass="subsection-title"/>
            </HBox>
            <ListView fx:id="listAutos" prefHeight="180" styleClass="modern-list-view" VBox.vgrow="ALWAYS"/>
        </VBox>

    </HBox>
    <Button text="Generar Ticket PDF"
            prefWidth="220"
            onAction="#generarPDF"/>
    <Button text="Volver al Home"
            prefWidth="240"
            prefHeight="40"
            onAction="#volverHome"
            styleClass="secondary-button"/>

</VBox>