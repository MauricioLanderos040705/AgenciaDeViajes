<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            stylesheets="@../css/styles.css"
            styleClass="main-background"
            fx:controller="org.example.agenciadeviajes.admin.AdminHomeController">

    <top>
        <VBox spacing="10"
              alignment="CENTER"
              styleClass="top-bar">

            <padding>
                <Insets top="20" bottom="20"/>
            </padding>

            <Label text="Panel de Administración"
                   styleClass="main-title"/>

            <Label fx:id="lblUsuario"
                   styleClass="welcome-label"/>
        </VBox>
    </top>

    <center>

        <VBox alignment="TOP_CENTER"
              spacing="15"
              styleClass="content-container">

            <padding>
                <Insets top="30" left="20" right="20" bottom="20"/>
            </padding>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Hoteles"
                        prefWidth="150"
                        prefHeight="40"
                        onAction="#abrirHoteles"
                        styleClass="primary-button"/>
                <Button text="Vuelos"
                        prefWidth="150"
                        prefHeight="40"
                        onAction="#abrirVuelos"
                        styleClass="primary-button"/>
                <Button text="Aerolíneas"
                        prefWidth="150"
                        prefHeight="40"
                        onAction="#abrirAerolineas"
                        styleClass="primary-button"/>
            </HBox>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Autos"
                        prefWidth="150"
                        prefHeight="40"
                        onAction="#abrirAutos"
                        styleClass="primary-button"/>
                <Button text="Ciudades"
                        prefWidth="150"
                        prefHeight="40"
                        onAction="#abrirCiudades"
                        styleClass="secondary-button"/>
                <Button text="Países"
                        prefWidth="150"
                        prefHeight="40"
                        onAction="#abrirPaises"
                        styleClass="secondary-button"/>
            </HBox>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Divisas"
                        prefWidth="150"
                        prefHeight="40"
                        onAction="#abrirDivisas"
                        styleClass="secondary-button"/>
                <Button text="Categorías Autos"
                        prefWidth="150"
                        prefHeight="40"
                        onAction="#abrirCategorias"
                        styleClass="secondary-button"/>
                <Button text="Modelos Autos"
                        prefWidth="150"
                        prefHeight="40"
                        onAction="#abrirModelos"
                        styleClass="secondary-button"/>
            </HBox>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Proveedores Autos"
                        prefWidth="150"
                        prefHeight="40"
                        onAction="#abrirProveedores"
                        styleClass="secondary-button"/>
                <Button text="Cerrar Sesión"
                        prefWidth="150"
                        prefHeight="40"
                        onAction="#cerrarSesion"
                        styleClass="danger-button"/>
            </HBox>

        </VBox>

    </center>

</BorderPane>
