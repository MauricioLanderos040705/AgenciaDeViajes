<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            stylesheets="@../css/styles.css"
            styleClass="main-background"
            fx:controller="org.example.agenciadeviajes.admin.ModeloAutoAdminController">

    <top>
        <VBox spacing="10"
              alignment="CENTER"
              styleClass="top-bar">

            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <Label text="Administrar Modelos de Autos"
                   styleClass="section-title"/>

        </VBox>
    </top>

    <center>

        <VBox spacing="15"
              styleClass="panel-surface"
              VBox.vgrow="ALWAYS">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <TableView fx:id="tablaModelos"
                       prefHeight="550"
                       VBox.vgrow="ALWAYS"
                       styleClass="modern-table">

                <columns>

                    <TableColumn fx:id="colId"
                                 text="ID"
                                 prefWidth="50"/>

                    <TableColumn fx:id="colMarca"
                                 text="Marca"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colModelo"
                                 text="Modelo"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colCategoria"
                                 text="Categoría"
                                 prefWidth="130"/>

                </columns>

            </TableView>

            <HBox spacing="15">

                <padding>
                    <Insets top="10"/>
                </padding>

                <Label text="Marca:"
                       prefWidth="80"/>
                <TextField fx:id="txtMarca"
                           prefWidth="200"/>

            </HBox>

            <HBox spacing="15">

                <Label text="Modelo:"
                       prefWidth="80"/>
                <TextField fx:id="txtModelo"
                           prefWidth="200"/>

            </HBox>

            <HBox spacing="15">

                <Label text="Categoría:"
                       prefWidth="80"/>
                <ComboBox fx:id="cbCategoria"
                          prefWidth="200"/>

            </HBox>

            <HBox spacing="10">

                <padding>
                    <Insets top="15"/>
                </padding>

                <Button fx:id="btnCrear"
                        text="Crear"
                        prefWidth="100"
                        onAction="#crearModelo"
                        styleClass="primary-button"/>

                <Button fx:id="btnActualizar"
                        text="Actualizar"
                        prefWidth="100"
                        onAction="#actualizarModelo"
                        styleClass="secondary-button"
                        disable="true"/>

                <Button fx:id="btnEliminar"
                        text="Eliminar"
                        prefWidth="100"
                        onAction="#eliminarModelo"
                        styleClass="danger-button"
                        disable="true"/>

                <Button fx:id="btnLimpiar"
                        text="Limpiar"
                        prefWidth="100"
                        onAction="#limpiar"
                        styleClass="secondary-button"/>

                <Separator prefWidth="30"/>

                <Button fx:id="btnRegresar"
                        text="← Regresar"
                        prefWidth="100"
                        onAction="#regresar"
                        styleClass="secondary-button"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>
