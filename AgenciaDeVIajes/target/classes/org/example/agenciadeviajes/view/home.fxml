<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            stylesheets="@../css/styles.css"
            styleClass="main-background"
            fx:controller="org.example.agenciadeviajes.controller.HomeController">

    <top>
        <VBox spacing="10"
              alignment="CENTER"
              styleClass="top-bar">

            <padding>
                <Insets top="20" bottom="20"/>
            </padding>

            <Label text="Agencia de Viajes"
                   styleClass="main-title"/>

            <Label fx:id="lblBienvenida"
                   styleClass="welcome-label"/>
        </VBox>
    </top>

    <center>

        <VBox alignment="CENTER"
              spacing="20"
              styleClass="content-container">

            <padding>
                <Insets top="40"/>
            </padding>

            <Button text="Consultar Vuelos"
                    prefWidth="260"
                    prefHeight="45"
                    onAction="#abrirVuelos"
                    styleClass="primary-button"/>

            <Button text="Consultar Hoteles"
                    prefWidth="260"
                    prefHeight="45"
                    onAction="#abrirHoteles"
                    styleClass="primary-button"/>

            <Button text="Consultar Autos"
                    prefWidth="260"
                    prefHeight="45"
                    onAction="#abrirAutos"
                    styleClass="primary-button"/>

            <Button text="Mis Reservas"
                    prefWidth="260"
                    prefHeight="45"
                    onAction="#abrirReservas"
                    styleClass="secondary-button"/>
            <Button text="Confirmar Reserva"
                    prefWidth="250"
                    onAction="#abrirConfirmarReserva"/>

            <Button text="Cerrar Sesión"
                    prefWidth="260"
                    prefHeight="45"
                    onAction="#cerrarSesion"
                    styleClass="danger-button"/>

        </VBox>

    </center>

</BorderPane>