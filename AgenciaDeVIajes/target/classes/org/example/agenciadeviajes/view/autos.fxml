<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.agenciadeviajes.controller.AutosController"
           stylesheets="@../css/styles.css">

    <Pane styleClass="page-background"/>

    <Pane styleClass="overlay"/>

    <BorderPane>

        <top>

            <VBox spacing="5">

                <padding>
                    <Insets top="24" left="30"/>
                </padding>

                <Label text="Consulta de Autos"
                       styleClass="page-title"/>

                <Label text="Renta el vehículo ideal"
                       styleClass="page-subtitle"/>

            </VBox>

        </top>

        <center>

            <VBox alignment="CENTER"
                  spacing="18">

                <padding>
                    <Insets top="10" right="25" bottom="25" left="25"/>
                </padding>

                <VBox spacing="18"
                      styleClass="glass-card"
                      maxWidth="1180">

                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <HBox spacing="12">

                        <DatePicker fx:id="dpFechaInicio"
                                    promptText="Fecha Inicio"/>

                        <DatePicker fx:id="dpFechaFin"
                                    promptText="Fecha Fin"/>

                    </HBox>

                    <TableView fx:id="tablaAutos"
                               prefHeight="430">

                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>

                        <columns>

                            <TableColumn fx:id="colMarca" text="Marca"/>
                            <TableColumn fx:id="colModelo" text="Modelo"/>
                            <TableColumn fx:id="colCategoria" text="Categoría"/>
                            <TableColumn fx:id="colProveedor" text="Proveedor"/>
                            <TableColumn fx:id="colCiudad" text="Ciudad"/>
                            <TableColumn fx:id="colPrecio" text="Precio/Día"/>

                        </columns>

                    </TableView>

                    <HBox spacing="18"
                          alignment="CENTER">

                        <Button text="🚘 Reservar Auto"
                                prefWidth="240"
                                prefHeight="42"
                                onAction="#reservarAuto"
                                styleClass="primary-btn"/>

                        <Button text="← Volver"
                                prefWidth="180"
                                prefHeight="42"
                                onAction="#volverHome"
                                styleClass="secondary-btn"/>

                    </HBox>

                </VBox>

            </VBox>

        </center>

    </BorderPane>

</StackPane>