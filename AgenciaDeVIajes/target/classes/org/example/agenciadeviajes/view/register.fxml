<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="12"
      stylesheets="@../css/styles.css"
      styleClass="auth-container"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.agenciadeviajes.controller.RegisterController">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Registro de Usuario"
           styleClass="auth-title"/>

    <TextField fx:id="txtNombre"
               promptText="Nombre"
               prefWidth="320"
               styleClass="modern-input"/>

    <TextField fx:id="txtApellido"
               promptText="Apellido"
               prefWidth="320"
               styleClass="modern-input"/>

    <TextField fx:id="txtCorreo"
               promptText="Correo"
               prefWidth="320"
               styleClass="modern-input"/>

    <PasswordField fx:id="txtPassword"
                   promptText="Contraseña"
                   prefWidth="320"
                   styleClass="modern-input"/>

    <Button text="Registrarse"
            prefWidth="220"
            onAction="#registrarUsuario"
            styleClass="primary-button"/>

    <Button text="Volver al Login"
            prefWidth="220"
            onAction="#volverLogin"
            styleClass="secondary-button"/>

    <Label fx:id="lblMensaje"
           styleClass="info-label"/>

</VBox>